# Backend
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGIN_PATTERNS=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=family_budget
DB_USERNAME=family_budget_user
DB_PASSWORD=change_me_locally

# JWT
JWT_SECRET=replace_with_a_long_random_secret_at_least_256_bits
JWT_EXPIRATION_MINUTES=1440

# Web frontend
FRONTEND_PORT=5173
# Optional. Leave unset for LAN testing so the frontend uses /api on the same hostname.
# You can set either the backend origin or full API base; the frontend will use /api.
# VITE_API_BASE_URL=http://localhost:8080
